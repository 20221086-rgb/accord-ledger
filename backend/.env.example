# Local development
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET=change-me-jwt-secret-min-32-chars-recommended
JWT_EXPIRES_SECONDS=3600
DATABASE_URL=sqlite:///accord_ledger.db
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
ALLOW_DEV_TEST_SIGNATURE=true

# Production (Render / Railway) — example
# FLASK_ENV=production
# SECRET_KEY=<openssl rand -hex 32>
# JWT_SECRET=<openssl rand -hex 32>
# DATABASE_URL=postgresql://user:pass@host/dbname
# CORS_ORIGIN=https://accord-ledger.vercel.app
# ALLOW_DEV_TEST_SIGNATURE=false
